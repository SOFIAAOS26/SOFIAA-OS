rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Regla base: denegar todo por defecto ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Perfiles de usuario (AuthContext + N.O.R.A) ───────────────────────────
    // CRÍTICO: cada usuario lee su propio perfil; admin lee todos (para N.O.R.A)
    match /usuarios/{uid} {
      allow read:  if request.auth != null &&
                      (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && isAdmin();
    }

    // ── Datos privados del usuario ────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // N.E.X.O. — Nodos de memoria
      match /nexo_nodes/{nodeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // N.E.X.O. — Biblioteca de PDFs personales
      match /biblioteca/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // N.E.X.O. — Eventos (solo lectura cliente, escritura Admin SDK)
      match /nexo_events/{eventId} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Long-term memory de SOFIAA
      match /memory/{memId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Pipeline observer / telemetría
      match /pipeline_events/{eventId} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── TEC BI — colecciones institucionales ─────────────────────────────────
    match /tec_bi/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── sofiaa_biblioteca — solo Admin SDK escribe; no se lee desde cliente ───
    match /sofiaa_biblioteca/{docId} {
      allow read, write: if false; // Admin SDK bypasses rules
    }

    // ── Función helper ────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth.token.email in [
        "u.cannmx@gmail.com"
        // Agrega más emails de admin aquí
      ];
    }
  }
}
