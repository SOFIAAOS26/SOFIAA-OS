rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Regla base: denegar todo por defecto ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Perfiles de usuario (AuthContext + N.O.R.A) ───────────────────────────
    // Lectura: cualquier usuario autenticado (nombre y rol no son datos sensibles)
    // N.O.R.A hace getDocs() de toda la colección → necesita allow list sin restricción por uid
    match /usuarios/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── Datos privados del usuario ────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // N.E.X.O. — Nodos de memoria
      match /nexo_nodes/{nodeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // N.E.X.O. — Biblioteca de PDFs personales
      match /biblioteca/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // N.E.X.O. — Eventos (solo lectura cliente, escritura Admin SDK)
      match /nexo_events/{eventId} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Long-term memory de SOFIAA
      match /memory/{memId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Cognitive Variables — perfil cognitivo adaptativo (Sprint M-3)
      match /cognitive_profile/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Pipeline observer / telemetría
      match /pipeline_events/{eventId} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // TEC Bii — entidades cognitivas (users/{uid}/tec_bii_{tipo}/{docId})
      match /tec_bii_proyectos/{docId}   { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /tec_bii_briefs/{docId}       { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /tec_bii_empleados/{docId}    { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /tec_bii_proveedores/{docId}  { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /tec_bii_clientes/{docId}     { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /tec_bii_evaluaciones/{docId} { allow read, write: if request.auth != null && request.auth.uid == uid; }

      // TEC Bii — reflexiones N.O.R.A. (generadas por Admin SDK + leídas por cliente)
      match /tec_bii_reflexiones/{reflId} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false; // solo Admin SDK escribe
      }

      // ATENA — Scientific Intelligence Engine
      match /atena_proyectos/{docId}   { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /atena_analisis/{docId}    { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /atena_spc/{docId}         { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /atena_amef/{docId}        { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /atena_financiero/{docId}  { allow read, write: if request.auth != null && request.auth.uid == uid; }
      match /atena_mediciones/{docId}  { allow read, write: if request.auth != null && request.auth.uid == uid; }
    }

    // ── TEC BI — colecciones institucionales ─────────────────────────────────
    // Lectura: cualquier usuario autenticado · Escritura: solo admin
    match /empleados/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /proveedores/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /clientes_internos/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /proyectos/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /briefs/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /evaluaciones/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── Marketing Sofia + PROMETEO — workspaces y sub-colecciones ───────────────
    // El wildcard /{sub}/{docId} cubre tanto smm_* como prometeo_* sub-colecciones:
    //   prometeo_goals, prometeo_brand_dna, prometeo_creative_memory,
    //   prometeo_fatigue_alerts, prometeo_campaign_creatives,
    //   prometeo_goal_states, prometeo_director_briefs, prometeo_creative_labs
    match /smm_workspaces/{workspaceId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();

      match /{sub}/{docId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && isAdmin();
      }
    }

    // ── sofiaa_biblioteca — solo Admin SDK escribe; no se lee desde cliente ───
    match /sofiaa_biblioteca/{docId} {
      allow read, write: if false; // Admin SDK bypasses rules
    }

    // ── Función helper ────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth.token.email in [
        "u.cannmx@gmail.com",
        "benjacob.urrutia@gmail.com"
      ];
    }
  }
}
